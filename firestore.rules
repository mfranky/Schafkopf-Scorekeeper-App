rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSessionMember(sessionId) {
      return signedIn()
        && exists(/databases/$(database)/documents/gameSessions/$(sessionId)/members/$(request.auth.uid));
    }

    match /gameSessionJoinCodes/{joinCode} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.sessionId is string;
      allow update, delete: if false;
    }

    match /gameSessions/{sessionId} {
      allow create: if signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.joinCode is string
        && request.resource.data.state is map;

      allow get: if isSessionMember(sessionId);
      allow update: if isSessionMember(sessionId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['state', 'revision', 'updatedAt', 'updatedByUid'])
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.state is map;
      allow list, delete: if false;

      match /members/{uid} {
        allow get: if isSessionMember(sessionId);
        allow list: if false;
        allow create, update: if signedIn()
          && uid == request.auth.uid
          && request.resource.data.role in ['owner', 'editor'];
        allow delete: if false;
      }
    }
  }
}
